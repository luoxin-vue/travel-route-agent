# ===== LLM（国产模型，OpenAI 兼容接口）=====
# 默认 DeepSeek；切 DeepSeek/GLM/通义 只需改这三项
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# deepseek-reasoner：推理模型，对话里展示「深度思考」思维链，但更慢
# 智谱 GLM 示例：
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_MODEL=glm-4-flash

# ===== 高德 =====
# Web 服务 key（供后端 MCP / REST 使用，与前端 JS key 不同）
AMAP_MAPS_API_KEY=your-amap-web-service-key

# 高德 MCP 接入方式：streamable_http（远程，推荐）/ sse（远程，旧）/ stdio（本地 npx）
AMAP_MCP_TRANSPORT=streamable_http

# ===== 服务 =====
CORS_ORIGINS=http://localhost:5173

# 出口代理：本机若需经代理访问外网（高德/LLM），填代理地址；直连可留空。
# 例如 Clash 默认：http://127.0.0.1:7897
PROXY_URL=
