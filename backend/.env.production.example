# 生产环境后端配置模板 —— 复制为 backend/.env 并填真实值。
# 与本机开发的最大区别：PROXY_URL 留空（国内服务器直连），CORS 指向线上域名。

# ===== LLM（DeepSeek，OpenAI 兼容）=====
LLM_API_KEY=sk-填你的-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ===== 高德 Web 服务 key（后端 MCP 用，与前端 JS key 不同）=====
AMAP_MAPS_API_KEY=填你的-高德Web服务key
AMAP_MCP_TRANSPORT=streamable_http

# ===== 服务 =====
# 同源托管下前端与 API 同域，此项主要用于跨域场景；填线上域名即可。
CORS_ORIGINS=https://coderlx.dpdns.org

# 出口代理：国内服务器可直连 DeepSeek/高德，务必留空！
# （127.0.0.1:7897 是本机 Clash 专用，服务器上没有这个代理，填了会全部请求失败）
PROXY_URL=
